# =============================================================================
# Invitation Service — Environment Variables (example)
# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public base URL used to build invitation links (e.g. https://sayyes.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Database — PostgreSQL (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invitation_service?schema=public"

# -----------------------------------------------------------------------------
# Session / Auth secret (used for session cookies / JWT signing)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
SESSION_SECRET="change-me-in-production"

# -----------------------------------------------------------------------------
# Payment provider (placeholders — replace with real provider keys)
# -----------------------------------------------------------------------------
PAYMENT_PROVIDER="mock"
PAYMENT_API_KEY=""
PAYMENT_WEBHOOK_SECRET=""
PAYMENT_PRICE_BASIC="49900"
PAYMENT_PRICE_PREMIUM="99900"

# -----------------------------------------------------------------------------
# Telegram bot (placeholder — replace with real bot token)
# Obtain a token from @BotFather
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
# Bot username (without @) used to build t.me/<bot>?start=<code> deep-links
TELEGRAM_BOT_USERNAME=""

# -----------------------------------------------------------------------------
# Cron secret (protects /api/cron/* endpoints)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=""

# -----------------------------------------------------------------------------
# S3-compatible object storage (placeholders — author photos)
# -----------------------------------------------------------------------------
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="invitation-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
